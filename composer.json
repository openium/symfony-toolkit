{
    "name": "openium/symfony-toolkit",
    "description": "Openium Web Toolkit for Symfony Project",
    "keywords": [
        "symfony",
        "bundle",
        "toolkit",
        "api",
        "openium"
    ],
    "type": "symfony-bundle",
    "license": "MIT",
    "homepage" : "https://www.openium.fr",
    "authors": [
        {
            "name": "Thomas Leduc",
            "email": "thomaslmoi15@hotmail.fr"
        },
        {
            "name": "Alexandre Caillot (Shiroe_sama)",
            "email": "a.caillot@openium.fr"
        },
        {
            "name": "Ophélie Coudert",
            "email": "o.coudert@openium.fr"
        }
    ],
    "autoload": {
        "psr-4": {
            "Openium\\SymfonyToolKitBundle\\": ""
        },
        "exclude-from-classmap": [
            "Tests/"
        ]
    },
    "require": {
        "php": "^8.4",
        "ext-json": "*",
        "ext-pdo": "*",
        "doctrine/orm": "^3.5",
        "doctrine/dbal": "^4",
        "doctrine/doctrine-bundle": "^3.0",
        "doctrine/doctrine-migrations-bundle": "^3.4",
        "symfony/http-foundation": "^8.0",
        "symfony/validator": "^8.0",
        "symfony/http-kernel": "^8.0",
        "symfony/dependency-injection": "^8.0",
        "symfony/config": "^8.0",
        "symfony/framework-bundle": "^8.0",
        "symfony/monolog-bridge": "^8.0",
        "symfony/event-dispatcher": "^8.0",
        "symfony/translation": "^8.0",
        "symfony/monolog-bundle": "^4.0",
        "symfony/security-core": "^8.0",
        "symfony/finder": "^8.0",
        "symfony/filesystem": "^8.0",
        "symfony/console": "^8.0",
        "symfony/security-http": "^8.0",
        "symfony/serializer": "^8.0",
        "symfony/doctrine-bridge": "^8.0"
    },
    "require-dev": {
        "phpstan/extension-installer": "^1.2",
        "phpstan/phpstan": "^1.10",
        "phpstan/phpstan-doctrine": "^1.3",
        "phpstan/phpstan-phpunit": "^1.2",
        "phpstan/phpstan-strict-rules": "^1.4",
        "phpstan/phpstan-symfony": "^1.3",
        "phpunit/phpunit": "^13.1",
        "rector/rector": "^1.2",
        "symfony/cache": "^8.0",
        "symfony/error-handler": "^8.0",
        "symfony/phpunit-bridge": "^8.0"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "^8.0"
        },
        "phpstan": {
            "includes": [
                "phpstan.neon"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    }
}
